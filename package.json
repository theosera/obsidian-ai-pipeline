{
  "name": "obsidian-ai-pipeline",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9.5.0"
  },
  "description": "Automated Obsidian Web Clipper pipeline (Claude flat impl.) + pnpm workspace X Bookmarks Sync (Codex impl.)",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "start": "tsx index.ts",
    "sync-rules": "tsx sync-rules.ts",
    "test": "tsx test_runner.ts",
    "dev:auth": "pnpm --filter @obsidian-ai-pipeline/core build && pnpm --filter auth dev",
    "sync": "pnpm --filter @obsidian-ai-pipeline/core build && pnpm --filter sync sync",
    "propose:grouping": "pnpm --filter @obsidian-ai-pipeline/core build && pnpm --filter sync propose:grouping",
    "approve:grouping": "pnpm --filter @obsidian-ai-pipeline/core build && pnpm --filter sync approve:grouping",
    "build": "pnpm -r build",
    "typecheck": "tsc --noEmit && pnpm --filter @obsidian-ai-pipeline/core build && pnpm -r typecheck"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@mozilla/readability": "^0.5.0",
    "better-sqlite3": "^11.7.0",
    "fast-xml-parser": "^5.5.9",
    "jsdom": "^25.0.0",
    "openai": "^6.32.0",
    "playwright": "^1.50.0",
    "string-similarity": "^4.0.4",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsdom": "^28.0.1",
    "@types/node": "catalog:",
    "@types/string-similarity": "^4.0.2",
    "@types/turndown": "^5.0.6",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
