+        """Bare repo URLs should be skipped (no /blob/, no fetch)."""
+        with patch.object(code_fetch, "_fetch_raw") as fetch:
+            snippets = code_fetch.fetch_snippets_for_urls(
+                ["https://github.com/anthropics/claude-code"]
