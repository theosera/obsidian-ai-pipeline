# X OAuth
X_CLIENT_ID=your_client_id
X_CLIENT_SECRET=
# Default (main): 3000. Codex experiment can use 3838.
X_REDIRECT_URI=http://localhost:3000/auth/callback
X_SCOPE=tweet.read users.read bookmark.read offline.access
X_AUTH_BASE_URL=https://twitter.com/i/oauth2
X_API_BASE_URL=https://api.x.com
AUTH_PORT=3000

# Paths
OBSIDIAN_VAULT_PATH=/absolute/path/to/ObsidianVault
# Default (main): Clippings/X_Bookmarks. Codex experiment can use Clippings/X-Bookmarks-codex.
X_BOOKMARKS_ROOT=Clippings/X_Bookmarks
SOURCE_ROOT=X_Bookmarks
PROPOSAL_PREFIX=codex
TOKENS_PATH=./data/tokens.json
PKCE_STATE_PATH=./data/pkce_state.json
