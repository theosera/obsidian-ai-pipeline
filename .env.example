# Paths
OBSIDIAN_VAULT_PATH=/absolute/path/to/ObsidianVault
X_BOOKMARKS_ROOT=Clippings/X-Bookmarks-codex
SOURCE_ROOT=Clippings/X-Bookmarks-codex
PROPOSAL_PREFIX=codex
